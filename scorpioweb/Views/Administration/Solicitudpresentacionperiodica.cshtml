@model List<Solicitudpresentacionperiodica>
@{
    ViewData["Title"] = "Solicitudpresentacionperiodica";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<script>
    $(document).on('change', '.chkAprobada', function () {

        let checkbox = $(this);
        let id = checkbox.data('id');

        if (checkbox.is(':checked')) {
            Swal.fire({
                title: "¿Ya está firmada la aprobación?",
                icon: "question",
                showCancelButton: true,
                confirmButtonText: "Sí"
            }).then((result) => {

                if (result.isConfirmed) {
                    actualizarSolicitud(id, 'Aprobada', 1);
                } else {
                    checkbox.prop('checked', false);
                }
            });
        } else {
            actualizarSolicitud(id, 'Aprobada', 0);
        }
    });


    // 🔥 SUBIDA
    $(document).on('change', '.chkSubida', function () {

        let checkbox = $(this);
        let id = checkbox.data('id');
        let nombre = checkbox.data('nombre');
        let fecha = checkbox.data('fecha');

        if (checkbox.is(':checked')) {
            Swal.fire({
                title: `¿Seguro que quieres subir la presentación de ${id}?`,
                text: `Fecha: ${fecha}`,
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Sí, subir"
            }).then((result) => {

                if (result.isConfirmed) {
                    actualizarSolicitud(id, 'Subida', 1);
                } else {
                    checkbox.prop('checked', false);
                }
            });
        } else {
            actualizarSolicitud(id, 'Subida', 0);
        }
    });

    // 🔥 AJAX
    function actualizarSolicitud(id, campo, valor) {
        $.ajax({
            url: '/Api/ActualizarSolicitud',
            type: 'POST',
            data: {
                id: id,
                campo: campo,
                valor: valor
            }
        });
    }
</script>


<h3>Solicitudes de Presentación Periódica</h3>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Área</th>
            <th>Id Persona</th>
            <th>Motivo</th>
            <th>Fecha Subsanada</th>
            <th>Fecha Registro</th>
            <th>Aprobada</th>
            <th>Subida</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Usuario</td>
                <td>@item.Area</td>
                <td>@item.Idpersona</td>
                <td>@item.Motivo</td>
                <td>@item.FechaSubsanada?.ToString("dd/MM/yyyy")</td>
                <td>@item.Fecha?.ToString("dd/MM/yyyy HH:mm")</td>

                <td>
                    <input type="checkbox"
                           class="chkAprobada"
                           data-id="@item.IdsolicitudPresentacionPeriodica"
                           @(item.Aprobada == 1 ? "checked" : "") />
                </td>

                <td>
                    <input type="checkbox"
                           class="chkSubida"
                           data-id="@item.IdsolicitudPresentacionPeriodica"
                           data-nombre="@item.Usuario"
                           data-fecha="@item.FechaSubsanada?.ToString("dd/MM/yyyy")"
                           @(item.Subida == 1 ? "checked" : "") />
                </td>
            </tr>
        }
    </tbody>
</table>